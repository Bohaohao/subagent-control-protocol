{
  "name": "subagent-control-protocol-marketplace",
  "interface": {
    "displayName": "Subagent Control Protocol Marketplace",
    "description": "Repo marketplace publishing the Subagent Control Protocol Codex plugin as a self-contained bundle with a bundled MCP runtime."
  },
  "plugins": [
    {
      "name": "subagent-control-protocol",
      "source": {
        "source": "local",
        "path": "./plugins/subagent-control-protocol"
      },
      "policy": {
        "installation": "AVAILABLE",
        "authentication": "ON_INSTALL"
      },
      "category": "Productivity"
    }
  ]
}
