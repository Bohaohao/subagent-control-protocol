{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent-result.schema.json",
  "title": "Claude subagent result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "summary",
    "filesChanged",
    "commandsRun",
    "verification",
    "risks",
    "nextSteps"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["completed", "partial", "blocked", "failed"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "filesChanged": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "change"],
        "properties": {
          "path": { "type": "string" },
          "change": { "type": "string" }
        }
      }
    },
    "commandsRun": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "status"],
        "properties": {
          "command": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "skipped", "not_run"]
          },
          "notes": { "type": "string" }
        }
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["check", "status"],
        "properties": {
          "check": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "skipped", "not_run"]
          },
          "evidence": { "type": "string" }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["risk", "severity"],
        "properties": {
          "risk": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "mitigation": { "type": "string" }
        }
      }
    },
    "nextSteps": {
      "type": "array",
      "items": { "type": "string" }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "tokensInput": { "type": "number" },
        "tokensOutput": { "type": "number" },
        "tokensTotal": { "type": "number" },
        "costUsd": { "type": "number" }
      }
    }
  }
}

